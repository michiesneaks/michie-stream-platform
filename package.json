{
  "name": "michie-stream-platform",
  "version": "1.0.0",
  "description": "Michie Stream Platform — Blockchain music & NFT streaming",
  "main": "src/server.cjs",
  "scripts": {
    "start": "node src/server.cjs",
    "dev": "nodemon src/server.cjs",
